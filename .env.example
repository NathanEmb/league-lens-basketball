# Required: Your ESPN fantasy basketball league ID
LEAGUE_ID=123456

# Optional: Dashboard name (default: "LeagueLens Basketball")
APP_NAME=LeagueLens Basketball

# Optional: Custom logo URL (default: basketball SVG)
LOGO_URL=

# Optional: Custom favicon URL (default: basketball SVG)
FAVICON_URL=

# Optional: Season year (default: current year)
YEAR=

# Optional: Server port inside container (default: 8000)
PORT=8000

# Optional: Host port to bind (default: 8000)
HOST_PORT=8000
